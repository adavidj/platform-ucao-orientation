# =================================================================
# UCAO-ORIENTATION — Variables d'environnement
# =================================================================
# Copier ce fichier en .env et remplir les valeurs

# Application
APP_ENV=dev
APP_DEBUG=true
APP_URL=http://localhost/ucao-orientation
APP_TIMEZONE=Africa/Porto-Novo

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ucao_orientation
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM_EMAIL=noreply@ucao.bj
SMTP_FROM_NAME=UCAO Orientation
SMTP_ENCRYPTION=tls
